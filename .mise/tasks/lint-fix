#!/usr/bin/env uvrs
# /// script
# requires-python = ">3.13"
# dependencies = ["pyyaml"]
#
# [tool.uv]
# exclude-newer = "2026-05-14T18:41:43Z"
# ///
# fmt: off
#MISE description="Fix auto-fixable recipe lint issues."
#USAGE flag "--vault-root <path>" help="Vault src/ directory (default: repo src/)"
#USAGE arg "[files]" var=#true help="Markdown files to fix (default: all in vault)"
# fmt: on

import importlib.util
import os
import re
import sys
from importlib.machinery import SourceFileLoader
from pathlib import Path

# Load shared logic from lint-check
_loader = SourceFileLoader("lint_check", str(Path(__file__).parent / "lint-check"))
_spec = importlib.util.spec_from_file_location(
    "lint_check", Path(__file__).parent / "lint-check", loader=_loader
)
_mod = importlib.util.module_from_spec(_spec)
_spec.loader.exec_module(_mod)

categorize = _mod.categorize
parse_file = _mod.parse_file
DEFAULT_VAULT_ROOT = _mod.DEFAULT_VAULT_ROOT


def fix_file(path: Path, vault_root: Path) -> list[str]:
    category = categorize(path, vault_root)
    if category != "recipe":
        return []
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---"):
        return []
    match = re.search(r"\n---(?:\n|$)", text)
    if not match:
        return []
    fm = __import__("yaml").safe_load(text[3 : match.start()]) or {}

    fixes = []
    new_text = text

    if "authors" in fm:
        new_text = re.sub(r"^authors:", "author:", new_text, flags=re.MULTILINE)
        fixes.append("renamed 'authors' → 'author'")
    if "category" in fm:
        new_text = re.sub(r"^category:.*(?:\n[ \t]+.*)*\n?", "", new_text, flags=re.MULTILINE)
        fixes.append("removed 'category' field")

    ing_match = re.search(r"## Ingredienser\s*\n(.*?)(?=\n##|\Z)", new_text, re.DOTALL)
    if ing_match and "#ingredient" not in ing_match.group(1):
        insert_at = ing_match.start(1)
        new_text = new_text[:insert_at] + "#ingredient\n\n" + new_text[insert_at:]
        fixes.append("added '#ingredient' tag")

    if fixes:
        path.write_text(new_text, encoding="utf-8")
    return fixes


def main():
    vault_root_str = os.environ.get("usage_vault_root", "")
    vault_root = (
        Path(vault_root_str).resolve()
        if vault_root_str
        else DEFAULT_VAULT_ROOT.resolve()
    )

    file_args = [a for a in sys.argv[1:] if a.endswith(".md")]
    paths: list[Path] = (
        [Path(f).resolve() for f in file_args]
        if file_args
        else sorted(vault_root.rglob("*.md"))
    )

    total_fixes = 0
    for path in paths:
        if not path.exists():
            continue
        fixes = fix_file(path, vault_root)
        if fixes:
            total_fixes += len(fixes)
            print(path)
            for f in fixes:
                print(f"  [FIX] {f}")
            print()

    if total_fixes:
        noun = "fix" if total_fixes == 1 else "fixes"
        print(f"{total_fixes} {noun} applied")


if __name__ == "__main__":
    main()
